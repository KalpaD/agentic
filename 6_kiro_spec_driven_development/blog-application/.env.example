# ─────────────────────────────────────────────────────────────────────────────
# Blog Application — Environment Variables
# Copy this file to .env and fill in the values for your environment.
#   cp .env.example .env
#
# NOTE: Never commit .env to source control. It is listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── API ───────────────────────────────────────────────────────────────────────

# Node environment — set to "development" locally, "production" in deployed envs
NODE_ENV=development

# Port the API server listens on
PORT=4000

# PostgreSQL connection string
# Format: postgres://<user>:<password>@<host>:<port>/<database>
# In Docker Compose the host is the service name "db"
DATABASE_URL=postgres://blog:blog@db:5432/blog

# Secret used to sign JWT access tokens (15-minute TTL)
# Change this to a long, random string in production
JWT_SECRET=change-me

# Secret used to sign JWT refresh tokens (7-day TTL)
# Change this to a different long, random string in production
JWT_REFRESH_SECRET=change-me

# ── Storage (MinIO local dev / S3 in production) ──────────────────────────────

# S3-compatible storage endpoint
# Local dev: http://minio:9000  (Docker service name)
# Production: https://s3.amazonaws.com  (or custom S3-compatible URL)
STORAGE_ENDPOINT=http://minio:9000

# Storage access key
# Local dev: minioadmin  (fixed MinIO dev credential)
# Production: AWS access key ID
STORAGE_ACCESS_KEY=minioadmin

# Storage secret key
# Local dev: minioadmin  (fixed MinIO dev credential — do NOT use in production)
# Production: AWS secret access key
STORAGE_SECRET_KEY=minioadmin

# Name of the S3 bucket used for image uploads
STORAGE_BUCKET=blog-images

# AWS/S3 region (used even for MinIO to satisfy SDK requirements)
STORAGE_REGION=us-east-1

# Public base URL for serving stored images to browsers
# Local dev: http://localhost:9000/blog-images  (MinIO served on host port 9000)
# Production: CDN URL or S3 public URL
STORAGE_PUBLIC_URL=http://localhost:9000/blog-images

# ── Frontend ──────────────────────────────────────────────────────────────────

# Base URL of the API — used by the React app for direct (non-proxied) requests
# In Docker Compose the proxy handles /api → http://api:4000 automatically
VITE_API_URL=http://localhost:4000
